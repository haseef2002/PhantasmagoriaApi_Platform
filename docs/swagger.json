{
  "openapi": "3.0.0",
  "info": {
    "title": "Phantasmagoria API",
    "description": "API documentation for the Alumni Influencers AR platform. Built to serve data to client-agnostic AR applications while managing a blind bidding influencer marketplace.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter your JWT token here to access authenticated Alumni routes."
      },
      "apiKeyAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Enter the Developer API Key to access the AR Client endpoints."
      }
    },
    "schemas": {
      "BidPayload": {
        "type": "object",
        "required": ["bidAmount", "targetDate"],
        "properties": {
          "bidAmount": {
            "type": "number",
            "format": "float",
            "description": "The monetary amount of the bid. Must be greater than 0 and higher than the user's previous bid.",
            "example": 50.50
          },
          "targetDate": {
            "type": "string",
            "format": "date",
            "description": "The future date the user is bidding to be Alumni of the Day.",
            "example": "2026-08-01"
          }
        }
      }
    }
  },

  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "description": "Creates a new user account. Enforces Westminster university email domains and strict password complexity.",
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "w1234567@westminster.ac.uk"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "example": "A12345@qwe"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registration successful. Verification email pending.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Registration successful. Please check your email to verify your account."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Validation Error (e.g., weak password, invalid domain, missing fields)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Password must be at least 8 characters long and include an uppercase letter, a number, and a special character."
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Conflict - Duplicate Email",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "This email is already registered. Please log in or reset your password."
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Internal server error during registration."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/api/auth/verify/{token}": {
      "get": {
        "summary": "Verify user email via single-use token",
        "tags": ["Authentication"],
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Email verified successfully." },
          "400": { "description": "Invalid or expired verification token." }
        }
      }
    },
    
"/api/auth/login": {
      "post": {
        "summary": "Login to receive a JWT session token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "student@my.westminster.ac.uk" },
                  "password": { "type": "string", "example": "SecurePass123!" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful. Returns JWT token." },
          "400": { "description": "Bad Request. Email and password are required." },
          "401": { "description": "Unauthorized. Invalid credentials." },
          "403": { "description": "Forbidden. Unverified email address." },
          "500": { "description": "Internal server error during login." }
        }
      }
    },
    
    "/api/auth/forgot-password": {
      "post": {
        "summary": "Request a password reset link",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "example": "student@my.westminster.ac.uk" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "If that email is registered, a reset link has been sent." },
          "500": { "description": "Internal server error." }
        }
      }
    },

    "/api/auth/reset-password/{token}": {
      "post": {
        "summary": "Submit a new password using a reset token",
        "tags": ["Authentication"],
        "parameters": [
          {
            "in": "path",
            "name": "token",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "newPassword": { "type": "string", "example": "NewSecurePass456!" }
                }
              }
            }
          }
        },
       "responses": {
          "200": { "description": "Password has been successfully reset." },
          "400": { "description": "Bad Request. Invalid/expired token or password too short." },
          "500": { "description": "Internal server error." }
        }
      }
    },
