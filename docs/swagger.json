    "/api/bids": {
      "post": {
        "summary": "Place or update a blind bid",
        "description": "Places a new bid or increases an existing bid for a specific date. Enforces the 3-win monthly limit and the increase-only rule.",
        "tags": ["Bidding"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BidPayload"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bid placed or updated successfully"
          },
          "400": {
            "description": "Bad Request - Invalid amount, past date, or bid not increased"
          },
          "403": {
            "description": "Forbidden - Monthly 3-win limit reached"
          }
        }
      }
    },
    "/api/bids/status": {
      "get": {
        "summary": "Check blind bid status",
        "description": "Returns whether the authenticated user is currently 'Winning' or 'Losing' for a specific date without revealing the actual highest bid amount.",
        "tags": ["Bidding"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "targetDate",
            "in": "query",
            "required": true,
            "description": "The date of the bid to check (YYYY-MM-DD)",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-08-01"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status retrieved successfully",
            "content": {
              "application/json": {
                "example": {
                  "targetDate": "2026-08-01",
                  "yourBid": "50.00",
                  "status": "Winning"
                }
              }
            }
          },
          "404": {
            "description": "No bid found for the user on this date"
          }
        }
      }
    },
    "api/bids/limits": {
      "get": {
        "summary": "Get remaining monthly bid slots",
        "description": "Calculates how many times the user has won in the target month and returns the remaining slots out of the maximum 3.",
        "tags": ["Bidding"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "targetDate",
            "in": "query",
            "required": false,
            "description": "Optional: Date to check limits against (defaults to today)",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Limits calculated successfully",
            "content": {
              "application/json": {
                "example": {
                  "month": 8,
                  "year": 2026,
                  "winsUsed": 1,
                  "remainingSlots": 2
                }
              }
            }
          }
        }
      }
    },
