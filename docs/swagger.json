    "/api/public/alumni-of-the-day": {
      "get": {
        "summary": "Fetch the current Alumni of the Day for the AR Client",
        "tags": ["AR Client Endpoint"],
        "security": [{ "apiKeyAuth": [] }],
        "responses": {
          "200": {
            "description": "Returns the winning profile and related professional data.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "profile": { "type": "object" },
                    "degrees": { "type": "array", "items": { "type": "object" } },
                    "employment": { "type": "array", "items": { "type": "object" } }
                  }
                }
              }
            }
          },
          "401": { "description": "Access denied. No API key provided." },
          "403": { "description": "Invalid or revoked API key." },
          "404": { "description": "No Alumni of the Day scheduled for today." }
        }
      }
    },
    
    "/api/auth/logout": {
